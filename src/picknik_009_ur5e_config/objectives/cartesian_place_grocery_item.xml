<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Cartesian Place Grocery Item">
  <BehaviorTree
    ID="Cartesian Place Grocery Item"
    _description="Detects a grocery item, vacuum picks it, navigates to Above Shelf waypoint, then uses a cartesian path to the place pose. Run Save Shelf Target first."
    _favorite="true"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <!--Clean up any leftover collision objects from previous runs-->
      <Decorator ID="ForceSuccess">
        <Action ID="DetachURDF" urdf_name="grocery_item" />
      </Decorator>
      <Decorator ID="ForceSuccess">
        <Action ID="RemoveURDFFromScene" urdf_name="grocery_item" />
      </Decorator>
      <!--Ensure vacuum is off at start-->
      <SubTree ID="Deactivate Vacuum" _collapsed="true" />
      <!--=== STEP 1: LOAD SHELF TARGET from YAML ===-->
      <Action
        ID="LoadTransformStampedFromYaml"
        file_path="shelf_target.yaml"
        output="{shelf_target_tf_stamped}"
      />
      <Action
        ID="ConvertTransformStampedToPoseStamped"
        transform_stamped="{shelf_target_tf_stamped}"
        pose_stamped="{shelf_target_pose}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="shelf_target"
        marker_size="0.050000"
        pose="{shelf_target_pose}"
        marker_text="shelf target"
      />
      <!--=== STEP 2: PERCEPTION — Detect grocery objects with shape fitting ===-->
      <SubTree
        ID="Move to Waypoint"
        _collapsed="true"
        waypoint_name="Scan 1"
        execution_pipeline="jtc"
        controller_action_server="/joint_trajectory_controller/follow_joint_trajectory"
        controller_names="joint_trajectory_controller"
      />
      <SubTree ID="Clear Snapshot" _collapsed="true" />
      <SubTree ID="Take Wrist Camera Image" _collapsed="true" />
      <SubTree ID="Get Wrist Camera Point Cloud" _collapsed="true" />
      <Action
        ID="GetMasks2DFromExemplar"
        model_package="picknik_009_ur5e_config"
        encoder_model_path="models/sam3_vision_encoder.onnx"
        decoder_model_path="models/sam3_decoder.onnx"
        geometry_encoder_model_path="models/sam3_geometry_encoder.onnx"
        text_encoder_model_path="models/sam3_text_encoder.onnx"
        confidence_threshold="0.5"
        confidence_scores_str="{confidence_scores_str}"
        target_image="{wrist_camera_image}"
        text_prompt="a tall red can of Pringles potato chips. There is a white design on the side and the lid of the can.  "
        confidence_scores="{confidence_scores}"
        masks2d="{masks2d}"
      />
      <Action
        ID="PublishMask2D"
        bounding_box_labels="{confidence_scores_str}"
        image="{wrist_camera_image}"
        masks="{masks2d}"
        masks_visualization_topic="/masks_visualization"
        opacity="0.500000"
      />
      <Action
        ID="TransformPointCloudFrame"
        input_cloud="{wrist_camera_point_cloud}"
        target_frame="world"
        output_cloud="{point_cloud_world}"
      />
      <Action
        ID="UpdatePlanningSceneService"
        point_cloud="{point_cloud_world}"
        point_cloud_service="/point_cloud_service"
      />
      <Action
        ID="GetMasks3DFromMasks2D"
        camera_info="{wrist_camera_info}"
        masks2d="{masks2d}"
        point_cloud="{point_cloud_world}"
        masks3d="{masks3d}"
      />
      <!--Run our custom shape-fitting behavior-->
      <Action
        ID="GetGraspableGroceryObjectsFromMasks3D"
        point_cloud="{point_cloud_world}"
        masks3d="{masks3d}"
        base_frame="world"
        plane_inlier_threshold="0.020000"
        minimum_face_area="0"
        face_separation_threshold="0.025000"
        shape_type="cylinder"
        graspable_objects="{grocery_objects}"
      />
      <!--Get the first detected object and compute place height from its shape-->
      <Action
        ID="GetElementOfVector"
        vector_in="{grocery_objects}"
        index="0"
        element="{graspable_object}"
      />
      <Action
        ID="ExtractGraspableObjectPose"
        graspable_object="{graspable_object}"
        pose="{object_pose}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="detected_object"
        marker_size="0.050000"
        pose="{object_pose}"
        marker_text="object"
      />
      <!--Compute place height based on shape type and grasp convention-->
      <Action
        ID="ComputeGroceryPlaceHeight"
        graspable_object="{graspable_object}"
        place_height="{place_height}"
        shape_type="{shape_type}"
      />
      <!--=== STEP 3: VACUUM PICK — plan to top of object, activate vacuum ===-->
      <!--Create pick pose at top surface of object, gripper pointing down-->
      <Action
        ID="OverridePoseOrientation"
        input_pose="{object_pose}"
        orientation_xyzw="1;0;0;0"
        output_pose="{pick_pose}"
      />
      <!--Offset from center to top surface: negative Z in flipped frame = up in world-->
      <Action
        ID="TransformPose"
        input_pose="{pick_pose}"
        output_pose="{pick_pose}"
        translation_xyz="{grasp_approach_translation_xyz}"
        quaternion_xyzw="0;0;0;1"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="pick"
        marker_size="0.050000"
        pose="{pick_pose}"
        marker_text="pick"
      />
      <!--MTC: plan to pick pose-->
      <Action
        ID="InitializeMTCTask"
        task="{mtc_task}"
        trajectory_monitoring="false"
        controller_names="joint_trajectory_controller"
        task_id="pick_grocery_item"
        timeout="-1.000000"
      />
      <Action ID="SetupMTCCurrentState" task="{mtc_task}" />
      <Action
        ID="SetupMTCPlanToPose"
        acceleration_scale_factor="1.000000"
        ik_frame="grasp_link"
        keep_orientation="false"
        keep_orientation_link_names="grasp_link"
        keep_orientation_tolerance="0.100000"
        link_padding="0.005000"
        max_iterations="10000"
        monitored_stage="current state"
        planning_group_name="manipulator"
        target_pose="{pick_pose}"
        task="{mtc_task}"
        trajectory_sampling_rate="100"
        velocity_scale_factor="1.000000"
      />
      <Action
        ID="PlanMTCTask"
        solution="{pick_solution}"
        task="{mtc_task}"
        max_solutions="3"
      />
      <Action ID="WaitForUserTrajectoryApproval" solution="{pick_solution}" />
      <SubTree
        ID="Execute MTC Solution"
        solution="{pick_solution}"
        execution_pipeline="jtc"
        controller_names="joint_trajectory_controller"
        controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
        _collapsed="true"
      />
      <!--Activate vacuum and try to grip, nudging down 1cm at a time if needed-->
      <SubTree ID="Activate Vacuum" _collapsed="true" />
      <Decorator ID="Repeat" num_cycles="3">
        <Control ID="Fallback" name="GripOrNudge">
          <!--Check if we have a grip-->
          <Control ID="Sequence" name="CheckGrip">
            <Action ID="WaitForDuration" delay_duration="2.0" />
            <Action
              ID="GetEpickObjectDetectionStatus"
              topic_name="/object_detection_status"
              message_out="{vacuum_status}"
            />
            <Control ID="Fallback">
              <Action
                ID="CompareEpickObjectDetectionStatus"
                value1="{vacuum_status}"
                value2="OBJECT_DETECTED_AT_MAX_PRESSURE"
              />
              <Action
                ID="CompareEpickObjectDetectionStatus"
                value1="{vacuum_status}"
                value2="OBJECT_DETECTED_AT_MIN_PRESSURE"
              />
            </Control>
          </Control>
          <!--No grip yet — nudge down 1cm and retry-->
          <Control ID="Sequence" name="NudgeDown">
            <Action
              ID="LogMessage"
              log_level="info"
              message="No vacuum grip detected. Nudging down 1cm..."
            />
            <Action
              ID="CreateStampedPose"
              reference_frame="grasp_link"
              stamped_pose="{nudge_pose}"
              position_xyz="0;0;0.01"
            />
            <Action ID="ResetPoseStampedVector" vector="{nudge_path}" />
            <Action
              ID="AddPoseStampedToVector"
              input="{nudge_pose}"
              vector="{nudge_path}"
            />
            <Action
              ID="PlanCartesianPath"
              acceleration_scale_factor="0.500000"
              blending_radius="0.005000"
              debug_solution="{debug_solution}"
              ik_cartesian_space_density="0.005000"
              ik_joint_space_density="0.050000"
              joint_trajectory_msg="{joint_trajectory_msg}"
              path="{nudge_path}"
              planning_group_name="manipulator"
              position_only="false"
              tip_links="grasp_link"
              trajectory_sampling_rate="100"
              velocity_scale_factor="0.100000"
            />
            <Action
              ID="ExecuteTrajectory"
              execution_pipeline="jtc"
              controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
            />
          </Control>
        </Control>
      </Decorator>
      <!--Final grip check after all attempts-->
      <Action
        ID="GetEpickObjectDetectionStatus"
        topic_name="/object_detection_status"
        message_out="{vacuum_status}"
      />
      <Control ID="Fallback" name="FinalGripCheck">
        <Action
          ID="CompareEpickObjectDetectionStatus"
          value1="{vacuum_status}"
          value2="OBJECT_DETECTED_AT_MAX_PRESSURE"
        />
        <Action
          ID="CompareEpickObjectDetectionStatus"
          value1="{vacuum_status}"
          value2="OBJECT_DETECTED_AT_MIN_PRESSURE"
        />
      </Control>
      <!--Retract straight up out of the bin-->
      <Action
        ID="CreateStampedPose"
        reference_frame="grasp_link"
        stamped_pose="{retract_above_bin}"
        position_xyz="0;0;-0.20"
      />
      <Action ID="ResetPoseStampedVector" vector="{retract_up_path}" />
      <Action
        ID="AddPoseStampedToVector"
        input="{retract_above_bin}"
        vector="{retract_up_path}"
      />
      <Action
        ID="PlanCartesianPath"
        acceleration_scale_factor="0.500000"
        blending_radius="0.010000"
        debug_solution="{debug_solution}"
        ik_cartesian_space_density="0.010000"
        ik_joint_space_density="0.100000"
        joint_trajectory_msg="{joint_trajectory_msg}"
        path="{retract_up_path}"
        planning_group_name="manipulator"
        position_only="false"
        tip_links="grasp_link"
        trajectory_sampling_rate="100"
        velocity_scale_factor="0.500000"
      />
      <Action
        ID="ExecuteTrajectory"
        execution_pipeline="jtc"
        controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
      />
      <!--Clear point cloud obstacles from perception so they don't block place planning-->
      <SubTree ID="Clear Snapshot" _collapsed="true" />
      <!--=== STEP 4: ADD HARDCODED COLLISION OBJECT ===-->
      <Action
        ID="GetLatestTransform"
        target_frame_id="world"
        source_frame_id="grasp_link"
        transform="{current_grasp_tf}"
      />
      <Action
        ID="ConvertTransformStampedToPoseStamped"
        transform_stamped="{current_grasp_tf}"
        pose_stamped="{current_grasp_pose}"
      />
      <Action
        ID="AddURDF"
        urdf_name="grocery_item"
        urdf_pose="{current_grasp_pose}"
        package_name="picknik_009_ur5e_config"
        urdf_file_path="description/grocery_item_collision.urdf"
      />
      <Action
        ID="AttachURDF"
        urdf_name="grocery_item"
        allowed_collision_links="grasp_link;epick_suction_cup;epick_extension;epick_body;epick_tcp"
        parent_link_name="grasp_link"
      />
      <!--=== STEP 5: NAVIGATE TO PLACE POSITION ===-->
      <!--On side: go to "I give Up" (reorients upright), then skip "Above Shelf"
        and go straight to cartesian place — maintaining orientation throughout.
        Upright: go to "Above Shelf" with keep_orientation to preserve grip.-->
      <Control ID="IfThenElse">
        <Action ID="Script" code="" _failureIf="is_on_side == false" />
        <!--THEN: on side — reorient via "I give Up", then "Above Shelf" keeping orientation-->
        <Control ID="Sequence">
          <SubTree
            ID="Move to Waypoint"
            _collapsed="true"
            waypoint_name="I give Up"
            execution_pipeline="jtc"
            controller_action_server="/joint_trajectory_controller/follow_joint_trajectory"
            controller_names="joint_trajectory_controller"
            acceleration_scale_factor="1.0"
          />
          <SubTree
            ID="Move to Waypoint"
            _collapsed="true"
            waypoint_name="Above Shelf"
            execution_pipeline="jtc"
            controller_action_server="/joint_trajectory_controller/follow_joint_trajectory"
            controller_names="joint_trajectory_controller"
            keep_orientation="true"
            keep_orientation_link_names="grasp_link"
            keep_orientation_tolerance="0.2"
          />
        </Control>
        <!--ELSE: upright — go to "Above Shelf" keeping orientation-->
        <Control ID="Fallback">
          <SubTree
            ID="Move to Waypoint"
            _collapsed="true"
            waypoint_name="Above Shelf"
            execution_pipeline="jtc"
            controller_action_server="/joint_trajectory_controller/follow_joint_trajectory"
            controller_names="joint_trajectory_controller"
            keep_orientation="true"
            keep_orientation_link_names="grasp_link"
            keep_orientation_tolerance="0.2"
          />
          <Control ID="Sequence">
            <Action
              ID="LogMessage"
              log_level="warn"
              message="Orientation-constrained move to Above Shelf failed. Retrying without constraint at reduced speed."
            />
            <SubTree
              ID="Move to Waypoint"
              _collapsed="true"
              waypoint_name="Above Shelf"
              execution_pipeline="jtc"
              controller_action_server="/joint_trajectory_controller/follow_joint_trajectory"
              controller_names="joint_trajectory_controller"
              velocity_scale_factor="0.3"
            />
          </Control>
        </Control>
      </Control>
      <!--=== STEP 5c: CARTESIAN PATH TO PLACE POSE ===-->
      <!--Compute end effector place pose:
        - Upright pick: gripper straight down (1,0,0,0), offset up by place_height in grasp frame
        - Side pick: keep current gripper orientation from "I give Up", set position to
          shelf target XY at shelf_z + place_height-->
      <Action
        ID="GetLatestTransform"
        target_frame_id="world"
        source_frame_id="grasp_link"
        transform="{pre_place_tf}"
      />
      <Action
        ID="ConvertTransformStampedToPoseStamped"
        transform_stamped="{pre_place_tf}"
        pose_stamped="{pre_place_pose}"
      />
      <!--Build place pose: shelf target position, gripper straight down, offset up by place_height.
        For on-side picks, the cartesian planner will use position_only mode to preserve orientation.-->
      <Action
        ID="OverridePoseOrientation"
        input_pose="{shelf_target_pose}"
        orientation_xyzw="1;0;0;0"
        output_pose="{place_pose}"
      />
      <Action
        ID="TransformPose"
        input_pose="{place_pose}"
        translation_xyz="{place_translation_xyz}"
        quaternion_xyzw="0;0;0;1"
        output_pose="{place_pose}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="place_target"
        marker_size="0.050000"
        pose="{place_pose}"
        marker_text="place"
      />
      <Action ID="ResetPoseStampedVector" vector="{place_path}" />
      <Action
        ID="AddPoseStampedToVector"
        input="{place_pose}"
        vector="{place_path}"
      />
      <!--On side: use position_only=true so the cartesian planner preserves the
        current orientation from "I give Up" and only moves to the target position.
        Upright: use position_only=false to also interpolate orientation to straight down.-->
      <Control ID="IfThenElse">
        <Action ID="Script" code="" _failureIf="is_on_side == false" />
        <!--THEN: on side — position only, preserve orientation-->
        <Action
          ID="PlanCartesianPath"
          acceleration_scale_factor="0.500000"
          blending_radius="0.010000"
          debug_solution="{debug_solution}"
          ik_cartesian_space_density="0.010000"
          ik_joint_space_density="0.050000"
          joint_trajectory_msg="{joint_trajectory_msg}"
          path="{place_path}"
          planning_group_name="manipulator"
          position_only="true"
          tip_links="grasp_link"
          trajectory_sampling_rate="100"
          velocity_scale_factor="0.300000"
        />
        <!--ELSE: upright — full pose including orientation-->
        <Action
          ID="PlanCartesianPath"
          acceleration_scale_factor="0.500000"
          blending_radius="0.010000"
          debug_solution="{debug_solution}"
          ik_cartesian_space_density="0.010000"
          ik_joint_space_density="0.050000"
          joint_trajectory_msg="{joint_trajectory_msg}"
          path="{place_path}"
          planning_group_name="manipulator"
          position_only="false"
          tip_links="grasp_link"
          trajectory_sampling_rate="100"
          velocity_scale_factor="0.300000"
        />
      </Control>
      <Action ID="WaitForUserTrajectoryApproval" solution="{debug_solution}" />
      <Action
        ID="ExecuteTrajectory"
        execution_pipeline="jtc"
        controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
      />
      <!--=== STEP 6: LOWER UNTIL CONTACT using force feedback ===-->
      <Action
        ID="SwitchController"
        activate_controllers="velocity_force_controller"
        controller_list_action_name="/controller_manager/list_controllers"
      />
      <Action
        ID="CallTriggerService"
        service_name="/velocity_force_controller/zero_fts"
      />
      <Action ID="WaitForDuration" delay_duration="1.0" />
      <Action
        ID="CreateStampedWrench"
        stamped_wrench="{desired_wrench}"
        reference_frame="grasp_link"
        torque_xyz="0;0;0"
        force_xyz="0;0;0"
      />
      <Action
        ID="CreateStampedTwist"
        reference_frame="grasp_link"
        stamped_twist="{desired_twist}"
        angular_velocity_xyz="0;0;0"
        linear_velocity_xyz="0;0;0.005"
      />
      <Action
        ID="CreateStampedPose"
        reference_frame="grasp_link"
        stamped_pose="{initial_pose}"
      />
      <Action ID="PushToSolutionQueue" />
      <Action
        ID="TransformPoseFrame"
        output_pose="{initial_pose}"
        input_pose="{initial_pose}"
      />
      <Control ID="Parallel" failure_count="1" success_count="1">
        <Action
          ID="ForceExceedsThreshold"
          minimum_consecutive_wrench_values="10"
          wrench_frame_name="tool0"
          hand_frame_name="grasp_link"
          force_threshold="5"
        />
        <Action
          ID="PublishVelocityForceCommand"
          force_controlled_axes="0;0;0;0;0;0"
          wrench_gain="0.01"
          velocity_controlled_axes="0;0;1;0;0;0"
          publish_rate="50"
        />
      </Control>
      <SubTree
        ID="Force Relaxation"
        _collapsed="true"
        wrench_gain="0.01"
        relaxation_time_ms="300"
        tip_link="grasp_link"
      />
      <Action
        ID="SwitchController"
        activate_controllers="joint_trajectory_controller"
      />
      <!--=== STEP 7: DEACTIVATE VACUUM, DETACH OBJECT, AND RETRACT ===-->
      <SubTree ID="Deactivate Vacuum" _collapsed="true" />
      <Action ID="WaitForDuration" delay_duration="1.0" />
      <!--Detach and remove the collision object from the planning scene-->
      <Action ID="DetachURDF" urdf_name="grocery_item" />
      <Action ID="RemoveURDFFromScene" urdf_name="grocery_item" />
      <!--Retract upward after releasing-->
      <Action
        ID="CreateStampedPose"
        reference_frame="grasp_link"
        stamped_pose="{retract_pose}"
        position_xyz="0;0;-0.1"
      />
      <Action ID="ResetPoseStampedVector" vector="{retract_path}" />
      <Action
        ID="AddPoseStampedToVector"
        input="{retract_pose}"
        vector="{retract_path}"
      />
      <Action
        ID="PlanCartesianPath"
        acceleration_scale_factor="1.000000"
        blending_radius="0.020000"
        debug_solution="{debug_solution}"
        ik_cartesian_space_density="0.010000"
        ik_joint_space_density="0.100000"
        joint_trajectory_msg="{joint_trajectory_msg}"
        path="{retract_path}"
        planning_group_name="manipulator"
        position_only="false"
        tip_links="grasp_link"
        trajectory_sampling_rate="100"
        velocity_scale_factor="1.000000"
      />
      <Action
        ID="ExecuteTrajectory"
        execution_pipeline="jtc"
        controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Cartesian Place Grocery Item">
      <MetadataFields>
        <Metadata subcategory="Application - Grocery" />
        <Metadata runnable="true" />
      </MetadataFields>
      <inout_port name="place_height" default="0.20">
        Height offset above shelf target (meters). Cylinder grasped in
        middle: full height.
      </inout_port>
      <inout_port name="place_translation_xyz" default="0;0;-0.20">
        Translation vector for place offset. Should be 0;0;-place_height.
      </inout_port>
      <inout_port name="scan_waypoint" default="Look at Right Bin">
        Name of the waypoint to move to for scanning objects.
      </inout_port>
      <inout_port name="text_prompt" default="grocery item">
        SAM3 text prompt describing what to detect.
      </inout_port>
    </SubTree>
  </TreeNodesModel>
</root>
