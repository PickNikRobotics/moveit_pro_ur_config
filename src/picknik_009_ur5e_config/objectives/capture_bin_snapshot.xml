<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Capture Bin Snapshot">
  <BehaviorTree
    ID="Capture Bin Snapshot"
    _description="Captures the scene (bin) camera RGB image and point cloud, transforms to world frame, and displays in UI."
    _favorite="true"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action
        ID="GetImage"
        topic_name="/camera/scene_camera/color/image_raw"
        message_out="{scene_camera_image}"
      />
      <Action
        ID="GetCameraInfo"
        topic_name="/camera/scene_camera/color/camera_info"
        message_out="{scene_camera_info}"
      />
      <Action
        ID="GetPointCloud"
        topic_name="/camera/scene_camera/depth/color/points"
        message_timeout_sec="15"
        message_out="{scene_camera_point_cloud}"
      />
      <Action
        ID="TransformPointCloudFrame"
        input_cloud="{scene_camera_point_cloud}"
        target_frame="world"
        output_cloud="{point_cloud_world}"
      />
      <Action ID="SendPointCloudToUI" point_cloud="{point_cloud_world}" />
      <Action
        ID="LogMessage"
        log_level="info"
        message="Bin camera snapshot captured and displayed. Verify point cloud aligns with calibrated scene."
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Capture Bin Snapshot">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Application - Grocery" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
