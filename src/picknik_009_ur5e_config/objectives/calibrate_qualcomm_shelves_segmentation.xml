<?xml version="1.0" encoding="UTF-8" ?>
<root
  BTCPP_format="4"
  main_tree_to_execute="Calibrate Qualcomm Shelves Segmentation"
>
  <BehaviorTree
    ID="Calibrate Qualcomm Shelves Segmentation"
    _description="Calibrates shelf location using SAM3 segmentation and point cloud ICP fitting. Captures wrist images from top and bottom shelf viewpoints, segments 'white metal shelf with black and white square fiducials' using SAM3, extracts masked point clouds, merges them, and fits the full shelf URDF via ICP."
    _favorite="true"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <!--=== CLEANUP previous calibration objects ===-->
      <Decorator ID="ForceSuccess">
        <Action ID="RemoveURDFFromScene" urdf_name="calibrated_shelf" />
      </Decorator>
      <Decorator ID="ForceSuccess">
        <Action ID="RemoveURDFFromScene" urdf_name="chunky_shelf_approx" />
      </Decorator>
      <SubTree ID="Clear Snapshot" _collapsed="true" />

      <!--=== PLACE CHUNKY SHELF for collision avoidance during calibration ===-->
      <Action
        ID="CreateStampedPose"
        position_xyz="0.0;0.66;-0.805"
        orientation_xyzw="0;0;1;0"
        reference_frame="world"
        stamped_pose="{chunky_shelf_pose}"
      />
      <Action
        ID="AddURDF"
        urdf_name="chunky_shelf_approx"
        urdf_pose="{chunky_shelf_pose}"
        package_name="picknik_009_ur5e_config"
        urdf_file_path="description/chunky_shelf.urdf"
      />
      <Action
        ID="LogMessage"
        log_level="info"
        message="Chunky shelf placed for collision avoidance. Starting SAM3 segmentation calibration..."
      />

      <!--=== TOP SHELF: Move, SAM3 segment, capture point cloud ===-->
      <SubTree
        ID="Segment Shelf at Waypoint"
        _collapsed="true"
        waypoint_name="Top Shelf Snapshot"
        segment_cloud="{top_segment_cloud}"
      />
      <Action
        ID="LogMessage"
        log_level="info"
        message="Top shelf segmented. Moving to bottom shelf..."
      />

      <!--=== BOTTOM SHELF: Move, SAM3 segment, capture point cloud ===-->
      <SubTree
        ID="Segment Shelf at Waypoint"
        _collapsed="true"
        waypoint_name="Bottom Shelf Snapshot"
        segment_cloud="{bottom_segment_cloud}"
      />
      <Action
        ID="LogMessage"
        log_level="info"
        message="Bottom shelf segmented. Moving to left shelf..."
      />

      <!--=== LEFT SHELF: Move, SAM3 segment, capture point cloud ===-->
      <SubTree
        ID="Segment Shelf at Waypoint"
        _collapsed="true"
        waypoint_name="Left Shelf Snapshot"
        segment_cloud="{left_segment_cloud}"
      />
      <Action
        ID="LogMessage"
        log_level="info"
        message="Left shelf segmented. Moving to right shelf..."
      />

      <!--=== RIGHT SHELF: Move, SAM3 segment, capture point cloud ===-->
      <SubTree
        ID="Segment Shelf at Waypoint"
        _collapsed="true"
        waypoint_name="Right Shelf Snapshot"
        segment_cloud="{right_segment_cloud}"
      />
      <Action
        ID="LogMessage"
        log_level="info"
        message="Right shelf segmented. Merging point clouds..."
      />

      <!--=== MERGE segmented point clouds from all viewpoints ===-->
      <Action
        ID="AddPointCloudToVector"
        point_cloud="{top_segment_cloud}"
        point_cloud_vector="{shelf_clouds}"
      />
      <Action
        ID="AddPointCloudToVector"
        point_cloud="{bottom_segment_cloud}"
        point_cloud_vector="{shelf_clouds}"
      />
      <Action
        ID="AddPointCloudToVector"
        point_cloud="{left_segment_cloud}"
        point_cloud_vector="{shelf_clouds}"
      />
      <Action
        ID="AddPointCloudToVector"
        point_cloud="{right_segment_cloud}"
        point_cloud_vector="{shelf_clouds}"
      />
      <Action
        ID="MergePointClouds"
        point_clouds="{shelf_clouds}"
        grid_resolution_meters="0.005"
        align_point_clouds="false"
        merged_cloud="{merged_shelf_cloud}"
      />

      <!--Clear previous snapshots so only the segmented cloud is visible-->
      <SubTree ID="Clear Snapshot" _collapsed="true" />

      <!--Publish merged cloud for debugging-->
      <Action
        ID="PublishPointCloud"
        point_cloud="{merged_shelf_cloud}"
        point_cloud_topic="/shelf_segment_cloud"
      />
      <Action ID="SendPointCloudToUI" point_cloud="{merged_shelf_cloud}" />

      <!--Save merged segmented cloud to file-->
      <Action
        ID="SavePointCloudToFile"
        file_path="~/.config/moveit_pro/saved_behavior_data"
        file_prefix="shelf_segmentation_cloud"
        point_cloud="{merged_shelf_cloud}"
      />

      <Action
        ID="LogMessage"
        log_level="info"
        message="Merged shelf point cloud published on /shelf_segment_cloud and saved. Ready for ICP fitting."
      />

      <!--=== ICP FIT SHELF MESH TO MERGED POINT CLOUD ===-->
      <!--Load the full shelf STL as a reference point cloud-->
      <Action
        ID="LoadPointCloudFromFile"
        color="255;0;0"
        package_name="picknik_009_ur5e_config"
        file_path="description/chunky_shelf.stl"
        point_cloud="{shelf_cad_cloud}"
      />
      <Action
        ID="TransformPointCloudFrame"
        input_cloud="{shelf_cad_cloud}"
        output_cloud="{shelf_cad_cloud}"
      />
      <!--Move CAD cloud to the initial guess pose (same as the chunky shelf placement)-->
      <Action
        ID="TransformPointCloud"
        input_cloud="{shelf_cad_cloud}"
        transform_pose="{chunky_shelf_pose}"
        output_cloud="{shelf_cad_cloud}"
      />

      <!--ICP: align CAD model to segmented sensor cloud-->
      <Action
        ID="RegisterPointClouds"
        base_point_cloud="{shelf_cad_cloud}"
        target_point_cloud="{merged_shelf_cloud}"
        max_correspondence_distance="0.5"
        max_iterations="100"
        target_pose_in_base_frame="{icp_correction}"
      />

      <!--Compose initial guess + ICP correction = final shelf pose in world frame-->
      <Action
        ID="TransformPoseWithPose"
        input_pose="{chunky_shelf_pose}"
        transform_pose="{icp_correction}"
        output_pose="{fitted_shelf_pose}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="fitted_shelf"
        marker_size="0.150000"
        pose="{fitted_shelf_pose}"
        marker_text="ICP Fitted Shelf"
      />

      <!--=== PLACE CALIBRATED SHELF URDF at ICP-fitted pose ===-->
      <Action ID="RemoveURDFFromScene" urdf_name="chunky_shelf_approx" />
      <Action
        ID="AddURDF"
        urdf_name="calibrated_shelf"
        urdf_pose="{fitted_shelf_pose}"
        package_name="picknik_009_ur5e_config"
        urdf_file_path="description/shelf.urdf"
      />
      <Action
        ID="SavePoseForUrdf"
        calibration_pose_stamped="{fitted_shelf_pose}"
        file_name="calibration/shelf_calibrated_pose.yaml"
      />
      <Action
        ID="SavePoseStampedToYaml"
        yaml_filename="calibration/shelf_pose.yaml"
        overwrite="true"
        message="{fitted_shelf_pose}"
      />
      <Action
        ID="LogMessage"
        log_level="info"
        message="Shelf segmentation + ICP calibration complete. Calibrated shelf.urdf placed and pose saved."
      />
    </Control>
  </BehaviorTree>

  <!--=== SUBTREE: Segment Shelf at Waypoint ===-->
  <BehaviorTree
    ID="Segment Shelf at Waypoint"
    _description="Moves to a waypoint, runs SAM3 segmentation for the shelf, projects masks to 3D, and extracts the segmented point cloud."
  >
    <Control ID="Sequence">
      <!--Move to the snapshot waypoint-->
      <SubTree
        ID="Move to Waypoint"
        _collapsed="true"
        waypoint_name="{waypoint_name}"
        execution_pipeline="jtc"
        controller_action_server="/joint_trajectory_controller/follow_joint_trajectory"
        controller_names="joint_trajectory_controller"
      />
      <Action ID="WaitForDuration" delay_duration="1.0" />

      <!--Capture wrist camera image-->
      <SubTree ID="Take Wrist Camera Image" _collapsed="true" />

      <!--SAM3: segment "white metal shelf with black and white square fiducials"-->
      <Action
        ID="GetMasks2DFromExemplar"
        model_package="picknik_009_ur5e_config"
        encoder_model_path="models/sam3_vision_encoder.onnx"
        decoder_model_path="models/sam3_decoder.onnx"
        geometry_encoder_model_path="models/sam3_geometry_encoder.onnx"
        text_encoder_model_path="models/sam3_text_encoder.onnx"
        confidence_threshold="0.5"
        confidence_scores_str="{confidence_scores_str}"
        target_image="{wrist_camera_image}"
        text_prompt="white metal shelf with black and white square fiducials"
        confidence_scores="{confidence_scores}"
        masks2d="{masks2d}"
      />

      <!--Visualize masks for debugging-->
      <Action
        ID="PublishMask2D"
        bounding_box_labels="{confidence_scores_str}"
        image="{wrist_camera_image}"
        masks="{masks2d}"
        masks_visualization_topic="/masks_visualization"
        opacity="0.500000"
      />

      <!--Capture wrist camera point cloud-->
      <SubTree ID="Get Wrist Camera Point Cloud" _collapsed="true" />

      <!--Project 2D masks to 3D using camera-frame point cloud (must match image pixels)-->
      <Action
        ID="GetMasks3DFromMasks2D"
        camera_info="{wrist_camera_info}"
        masks2d="{masks2d}"
        point_cloud="{wrist_camera_point_cloud}"
        masks3d="{masks3d}"
      />

      <!--Get the highest-confidence mask-->
      <Action
        ID="GetElementOfVector"
        vector_in="{masks3d}"
        index="0"
        element="{best_mask3d}"
      />

      <!--Extract the segmented point cloud using the 3D mask (still in camera frame)-->
      <Action
        ID="GetPointCloudFromMask3D"
        point_cloud="{wrist_camera_point_cloud}"
        mask3d="{best_mask3d}"
        point_cloud_fragment="{segment_cloud_camera}"
      />

      <!--Transform segmented cloud to world frame-->
      <Action
        ID="TransformPointCloudFrame"
        input_cloud="{segment_cloud_camera}"
        target_frame="world"
        output_cloud="{segment_cloud_uncropped}"
      />

      <!--Crop to a reasonable volume around the shelf to remove spurious depth points-->
      <Action
        ID="CreateStampedPose"
        position_xyz="0.0;0.66;0.145"
        orientation_xyzw="0;0;0;1"
        reference_frame="world"
        stamped_pose="{crop_center}"
      />
      <Action
        ID="CropPointsInBox"
        crop_box_centroid_pose="{crop_center}"
        point_cloud="{segment_cloud_uncropped}"
        point_cloud_cropped="{segment_cloud}"
        crop_box_size="2.1;1.3;2.6"
      />
    </Control>
  </BehaviorTree>

  <TreeNodesModel>
    <SubTree ID="Calibrate Qualcomm Shelves Segmentation">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Application - Grocery" />
      </MetadataFields>
    </SubTree>
    <SubTree ID="Segment Shelf at Waypoint">
      <MetadataFields>
        <Metadata runnable="false" />
        <Metadata subcategory="Application - Grocery" />
      </MetadataFields>
      <input_port name="waypoint_name" default="{waypoint_name}">
        Waypoint to move to for shelf snapshot.
      </input_port>
      <inout_port name="segment_cloud" default="{segment_cloud}">
        Segmented point cloud output for this viewpoint.
      </inout_port>
    </SubTree>
  </TreeNodesModel>
</root>
