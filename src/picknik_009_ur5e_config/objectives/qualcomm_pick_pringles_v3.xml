<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Qualcomm Pick Pringles v3">
  <BehaviorTree
    ID="Qualcomm Pick Pringles v3"
    _description="Scene-camera Pringles pick and place. Detects via SAM3, fits cylinder, vacuum picks from bin, places upright at the designated shelf zone. Run Calibrate Detected April Tags and Calibrate Scene Camera first."
    _favorite="true"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <!--=== CLEANUP ===-->
      <SubTree ID="Reset Planning Scene" _collapsed="true" />
      <Decorator ID="ForceSuccess">
        <Action ID="DetachURDF" urdf_name="grocery_item" />
      </Decorator>
      <Decorator ID="ForceSuccess">
        <Action ID="RemoveURDFFromScene" urdf_name="grocery_item" />
      </Decorator>
      <SubTree ID="Deactivate Vacuum" _collapsed="true" />

      <!--=== LOAD CALIBRATED SCENE ===-->
      <SubTree ID="Load Calibrated Scene" _collapsed="true" />

      <!--=== STEP 1: LOOK UP PRINGLES PLACEMENT ZONE FROM CONFIG ===-->
      <Action
        ID="LoadPoseStampedFromYaml"
        file_path="calibration/top_shelf_pose.yaml"
        output="{top_shelf_pose}"
      />
      <Action
        ID="LoadPoseStampedFromYaml"
        file_path="calibration/bottom_shelf_pose.yaml"
        output="{bottom_shelf_pose}"
      />
      <Action
        ID="GetPlacementPoseForObject"
        top_shelf_pose="{top_shelf_pose}"
        bottom_shelf_pose="{bottom_shelf_pose}"
        object_name="pringles"
        placement_pose="{pringles_place_pose}"
        shelf_name="{shelf_name}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="pringles_placement"
        marker_size="0.100000"
        pose="{pringles_place_pose}"
        marker_text="Pringles Placement Zone"
      />

      <!--=== STEP 2: MOVE TO BIN AND CAPTURE SCENE CAMERA ===-->
      <SubTree
        ID="Move to Waypoint"
        _collapsed="true"
        waypoint_name="Above Grocery Bin"
        execution_pipeline="jtc"
        controller_action_server="/joint_trajectory_controller/follow_joint_trajectory"
        controller_names="joint_trajectory_controller"
      />
      <Action
        ID="GetImage"
        topic_name="/camera/scene_camera/color/image_raw"
        message_out="{scene_camera_image}"
      />
      <Action
        ID="GetCameraInfo"
        topic_name="/camera/scene_camera/color/camera_info"
        message_out="{scene_camera_info}"
      />
      <Action
        ID="GetPointCloud"
        topic_name="/camera/scene_camera/depth/color/points"
        message_timeout_sec="15"
        message_out="{scene_camera_point_cloud}"
      />

      <!--=== STEP 3: SEGMENT PRINGLES USING SAM3 ===-->
      <Action
        ID="LoadImageFromFile"
        file_path="~/user_ws/qualcomm_image_exemplars/pringles.png"
        frame_id="camera"
        image="{pringles_exemplar_image}"
      />
      <Action
        ID="GetMasks2DFromExemplar"
        model_package="picknik_009_ur5e_config"
        encoder_model_path="models/sam3_vision_encoder.onnx"
        decoder_model_path="models/sam3_decoder.onnx"
        geometry_encoder_model_path="models/sam3_geometry_encoder.onnx"
        text_encoder_model_path="models/sam3_text_encoder.onnx"
        confidence_threshold="0.5"
        confidence_scores_str="{confidence_scores_str}"
        target_image="{scene_camera_image}"
        exemplar_image="{pringles_exemplar_image}"
        text_prompt="a tall red can of Pringles potato chips. There is a white design on the side and the lid of the can."
        confidence_scores="{confidence_scores}"
        masks2d="{masks2d}"
      />
      <Action
        ID="PublishMask2D"
        bounding_box_labels="{confidence_scores_str}"
        image="{scene_camera_image}"
        masks="{masks2d}"
        masks_visualization_topic="/masks_visualization"
        opacity="0.500000"
      />

      <!--=== STEP 4: FIT CYLINDER TO SEGMENTED POINT CLOUD ===-->
      <Action
        ID="TransformPointCloudFrame"
        input_cloud="{scene_camera_point_cloud}"
        target_frame="world"
        output_cloud="{point_cloud_world}"
      />
      <Action ID="SendPointCloudToUI" point_cloud="{point_cloud_world}" />
      <Action
        ID="GetMasks3DFromMasks2D"
        camera_info="{scene_camera_info}"
        masks2d="{masks2d}"
        point_cloud="{point_cloud_world}"
        masks3d="{masks3d}"
      />
      <Action
        ID="GetGraspableGroceryObjectsFromMasks3D"
        point_cloud="{point_cloud_world}"
        masks3d="{masks3d}"
        base_frame="world"
        plane_inlier_threshold="0.020000"
        minimum_face_area="0"
        face_separation_threshold="0.025000"
        max_objects="1"
        shape_type="cylinder"
        graspable_objects="{grocery_objects}"
        segment_cloud="{segment_cloud}"
      />
      <Action
        ID="PublishPointCloud"
        point_cloud="{segment_cloud}"
        point_cloud_topic="/grocery_segment_cloud"
      />
      <Action ID="SendPointCloudToUI" point_cloud="{segment_cloud}" />

      <!--=== STEP 5: EXTRACT OBJECT AND COMPUTE PICK POSE ===-->
      <Action
        ID="GetElementOfVector"
        vector_in="{grocery_objects}"
        index="0"
        element="{graspable_object}"
      />
      <Action
        ID="ExtractGraspableObjectPose"
        graspable_object="{graspable_object}"
        pose="{object_pose}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="detected_object"
        marker_size="0.050000"
        pose="{object_pose}"
        marker_text="Pringles (cylinder center)"
      />
      <Action
        ID="ComputeGroceryPlaceHeight"
        graspable_object="{graspable_object}"
        place_height="{place_height}"
        place_translation_xyz="{place_translation_xyz}"
        grasp_approach_translation_xyz="{grasp_approach_translation_xyz}"
        shape_type="{shape_type}"
        depth_offset="{depth_offset}"
        collision_dimensions="{collision_dimensions}"
      />
      <!--Pick pose: gripper pointing down at top of object-->
      <Action
        ID="OverridePoseOrientation"
        input_pose="{object_pose}"
        orientation_xyzw="1;0;0;0"
        output_pose="{pick_pose}"
      />
      <Action
        ID="TransformPose"
        input_pose="{pick_pose}"
        output_pose="{pick_pose}"
        translation_xyz="{grasp_approach_translation_xyz}"
        quaternion_xyzw="0;0;0;1"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="pick_point"
        marker_size="0.050000"
        pose="{pick_pose}"
        marker_text="Pick Point"
      />

      <!--=== STEP 6: MTC PLAN AND EXECUTE TO PICK POSE ===-->
      <!--Clear octomap so bin contents don't block pick planning-->
      <SubTree ID="Clear Snapshot" _collapsed="true" />
      <Action
        ID="InitializeMTCTask"
        task="{mtc_task}"
        trajectory_monitoring="false"
        controller_names="joint_trajectory_controller"
        task_id="pick_pringles_v3"
        timeout="-1.000000"
      />
      <Action ID="SetupMTCCurrentState" task="{mtc_task}" />
      <Action
        ID="SetupMTCPlanToPose"
        acceleration_scale_factor="1.000000"
        ik_frame="grasp_link"
        keep_orientation="false"
        keep_orientation_link_names="grasp_link"
        keep_orientation_tolerance="0.100000"
        link_padding="0.005000"
        max_iterations="10000"
        monitored_stage="current state"
        planning_group_name="manipulator"
        target_pose="{pick_pose}"
        task="{mtc_task}"
        trajectory_sampling_rate="100"
        velocity_scale_factor="1.000000"
      />
      <Action
        ID="PlanMTCTask"
        solution="{pick_solution}"
        task="{mtc_task}"
        max_solutions="3"
      />
      <Action ID="WaitForUserTrajectoryApproval" solution="{pick_solution}" />
      <SubTree
        ID="Execute MTC Solution"
        solution="{pick_solution}"
        execution_pipeline="jtc"
        controller_names="joint_trajectory_controller"
        controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
        _collapsed="true"
      />

      <!--=== STEP 7: ACTIVATE VACUUM AND NUDGE UNTIL GRIP ===-->
      <SubTree ID="Activate Vacuum" _collapsed="true" />
      <Decorator ID="Repeat" num_cycles="3">
        <Control ID="Fallback" name="GripOrNudge">
          <Control ID="Sequence" name="CheckGrip">
            <Action ID="WaitForDuration" delay_duration="2.0" />
            <Action
              ID="GetEpickObjectDetectionStatus"
              topic_name="/object_detection_status"
              message_out="{vacuum_status}"
            />
            <Control ID="Fallback">
              <Action ID="CompareEpickObjectDetectionStatus" value1="{vacuum_status}" value2="OBJECT_DETECTED_AT_MAX_PRESSURE" />
              <Action ID="CompareEpickObjectDetectionStatus" value1="{vacuum_status}" value2="OBJECT_DETECTED_AT_MIN_PRESSURE" />
            </Control>
          </Control>
          <Control ID="Sequence" name="NudgeDown">
            <Action ID="LogMessage" log_level="info" message="No vacuum grip detected. Nudging down 1cm..." />
            <Action ID="CreateStampedPose" reference_frame="grasp_link" stamped_pose="{nudge_pose}" position_xyz="0;0;0.01" />
            <Action ID="ResetPoseStampedVector" vector="{nudge_path}" />
            <Action ID="AddPoseStampedToVector" input="{nudge_pose}" vector="{nudge_path}" />
            <Action
              ID="PlanCartesianPath"
              acceleration_scale_factor="0.500000"
              blending_radius="0.005000"
              debug_solution="{debug_solution}"
              ik_cartesian_space_density="0.005000"
              ik_joint_space_density="0.050000"
              joint_trajectory_msg="{joint_trajectory_msg}"
              path="{nudge_path}"
              planning_group_name="manipulator"
              position_only="false"
              tip_links="grasp_link"
              trajectory_sampling_rate="100"
              velocity_scale_factor="0.100000"
            />
            <Action
              ID="ExecuteTrajectory"
              execution_pipeline="jtc"
              controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
            />
          </Control>
        </Control>
      </Decorator>
      <!--Final grip check-->
      <Action
        ID="GetEpickObjectDetectionStatus"
        topic_name="/object_detection_status"
        message_out="{vacuum_status}"
      />
      <Control ID="Fallback" name="FinalGripCheck">
        <Action ID="CompareEpickObjectDetectionStatus" value1="{vacuum_status}" value2="OBJECT_DETECTED_AT_MAX_PRESSURE" />
        <Action ID="CompareEpickObjectDetectionStatus" value1="{vacuum_status}" value2="OBJECT_DETECTED_AT_MIN_PRESSURE" />
      </Control>

      <!--=== ATTACH COLLISION OBJECT (before retract, while grasp_link is still at pick pose) ===-->
      <!--Place at object_pose so the relative transform between grasp_link and
           the object is captured correctly at pick time. -->
      <Action
        ID="GenerateShapeUrdf"
        shape_type="{shape_type}"
        dimensions="{collision_dimensions}"
        object_name="grocery_item"
        origin_offset_z="0.0"
        urdf_file_path="/tmp/grocery_item_collision.urdf"
        output_file_path="{generated_urdf_path}"
      />
      <Action
        ID="AddURDF"
        urdf_name="grocery_item"
        urdf_pose="{object_pose}"
        package_name=""
        urdf_file_path="{generated_urdf_path}"
      />
      <Action
        ID="AttachURDF"
        urdf_name="grocery_item"
        allowed_collision_links="grasp_link;epick_suction_cup;epick_extension;epick_body;epick_tcp"
        parent_link_name="grasp_link"
      />

      <!--=== STEP 8: RETRACT FROM BIN ===-->
      <Action
        ID="CreateStampedPose"
        reference_frame="grasp_link"
        stamped_pose="{retract_above_bin}"
        position_xyz="0;0;-0.20"
      />
      <Action ID="ResetPoseStampedVector" vector="{retract_up_path}" />
      <Action ID="AddPoseStampedToVector" input="{retract_above_bin}" vector="{retract_up_path}" />
      <Action
        ID="PlanCartesianPath"
        acceleration_scale_factor="0.500000"
        blending_radius="0.010000"
        debug_solution="{debug_solution}"
        ik_cartesian_space_density="0.010000"
        ik_joint_space_density="0.100000"
        joint_trajectory_msg="{joint_trajectory_msg}"
        path="{retract_up_path}"
        planning_group_name="manipulator"
        position_only="false"
        tip_links="grasp_link"
        trajectory_sampling_rate="100"
        velocity_scale_factor="0.500000"
      />
      <Action
        ID="ExecuteTrajectory"
        execution_pipeline="jtc"
        controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
      />

      <!--Clear point cloud obstacles so they don't block place planning-->
      <SubTree ID="Clear Snapshot" _collapsed="true" />

      <!--=== STEP 9: RETURN TO ABOVE GROCERY BIN ===-->
      <SubTree
        ID="Move to Waypoint"
        _collapsed="true"
        waypoint_name="Above Grocery Bin"
        execution_pipeline="jtc"
        controller_action_server="/joint_trajectory_controller/follow_joint_trajectory"
        controller_names="joint_trajectory_controller"
      />

      <!--=== STEP 10: MOVE TO SHELF STAGING WAYPOINT ===-->
      <!--Top shelf → Top Shelf Staging, bottom shelf → Bottom Shelf Staging-->
      <Control ID="Fallback" name="SelectStagingWaypoint">
        <Control ID="Sequence" name="TopShelfPath">
          <Action ID="Script" code="" _failureIf="shelf_name != 'top_shelf'" />
          <SubTree
            ID="Move to Waypoint"
            _collapsed="true"
            waypoint_name="Top Shelf Staging"
            execution_pipeline="jtc"
            controller_action_server="/joint_trajectory_controller/follow_joint_trajectory"
            controller_names="joint_trajectory_controller"
          />
        </Control>
        <Control ID="Sequence" name="BottomShelfPath">
          <SubTree
            ID="Move to Waypoint"
            _collapsed="true"
            waypoint_name="Bottom Shelf Staging"
            execution_pipeline="jtc"
            controller_action_server="/joint_trajectory_controller/follow_joint_trajectory"
            controller_names="joint_trajectory_controller"
          />
        </Control>
      </Control>

      <!--=== STEP 11: COMPUTE PLACE POSE AND PLAN ===-->
      <!--ComputePlaceOrientation determines the correct grasp_link orientation so the
           object ends up upright on the shelf (long axis normal to shelf surface).
           It accounts for how the object was picked and computes the height offset. -->
      <Action
        ID="ComputePlaceOrientation"
        object_pose="{object_pose}"
        pick_pose="{pick_pose}"
        place_position="{pringles_place_pose}"
        height_offset="{place_height}"
        depth_offset="{depth_offset}"
        place_pose="{place_pose}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="place_target"
        marker_size="0.050000"
        pose="{place_pose}"
        marker_text="Place Target"
      />
      <Action
        ID="SavePoseStampedToYaml"
        yaml_filename="calibration/place_target_pose.yaml"
        overwrite="true"
        message="{place_pose}"
      />
      <!--Capture current EE orientation for fallback-->
      <Action
        ID="GetLatestTransform"
        target_frame_id="world"
        source_frame_id="grasp_link"
        transform="{current_ee_tf}"
      />
      <Action
        ID="ConvertTransformStampedToPoseStamped"
        transform_stamped="{current_ee_tf}"
        pose_stamped="{current_ee_pose}"
      />

      <Control ID="Fallback" name="TryComputedThenCurrentOrientation">
        <!--=== ATTEMPT 1: Computed place orientation ===-->
        <Control ID="Sequence" name="ComputedOrientation">
          <Action
            ID="InitializeMTCTask"
            controller_names="joint_trajectory_controller"
            task="{mtc_task}"
            task_id="place_pringles_v3"
            trajectory_monitoring="false"
            timeout="-1.000000"
          />
          <Action ID="SetupMTCCurrentState" task="{mtc_task}" />
          <Action
            ID="SetupMTCIgnoreCollisionsBetweenObjects"
            allow_collision="true"
            task="{mtc_task}"
            object_names="grocery_item;grasp_link;epick_suction_cup;epick_extension;epick_body;epick_tcp"
          />
          <Action
            ID="SetupMTCIgnoreCollisionsBetweenObjects"
            allow_collision="true"
            task="{mtc_task}"
            object_names="grocery_item;calibrated_top_shelf;calibrated_bottom_shelf;shelf_back;shelf_base;calibrated_bin;calibrated_pole;calibrated_camera;calibrated_table"
          />
          <Action
            ID="SetupMTCPlanToPose"
            acceleration_scale_factor="1.000000"
            ik_frame="grasp_link"
            keep_orientation="false"
            keep_orientation_link_names="grasp_link"
            keep_orientation_tolerance="0.100000"
            link_padding="0.005"
            max_iterations="5000"
            monitored_stage="current state"
            planning_group_name="manipulator"
            target_pose="{place_pose}"
            task="{mtc_task}"
            trajectory_sampling_rate="100"
            velocity_scale_factor="0.500000"
          />
          <Action
            ID="PlanMTCTask"
            solution="{place_solution}"
            task="{mtc_task}"
            max_solutions="10"
          />
        </Control>

        <!--=== ATTEMPT 2: Use current EE orientation as fallback ===-->
        <Control ID="Sequence" name="CurrentEEOrientation">
          <Action
            ID="LogMessage"
            log_level="info"
            message="Computed place orientation failed IK. Retrying with current EE orientation..."
          />
          <!--Keep place_pose position, override orientation with current EE orientation-->
          <Action
            ID="ExtractPoseOrientation"
            input_pose="{current_ee_pose}"
            orientation_xyzw="{current_ee_orientation}"
          />
          <Action
            ID="OverridePoseOrientation"
            input_pose="{place_pose}"
            orientation_xyzw="{current_ee_orientation}"
            output_pose="{place_pose_fallback}"
          />
          <Action
            ID="VisualizePose"
            marker_lifetime="0.000000"
            marker_name="place_target_fallback"
            marker_size="0.050000"
            pose="{place_pose_fallback}"
            marker_text="Place Target (current EE orientation)"
          />
          <Action
            ID="InitializeMTCTask"
            controller_names="joint_trajectory_controller"
            task="{mtc_task}"
            task_id="place_pringles_v3_fallback"
            trajectory_monitoring="false"
            timeout="-1.000000"
          />
          <Action ID="SetupMTCCurrentState" task="{mtc_task}" />
          <Action
            ID="SetupMTCIgnoreCollisionsBetweenObjects"
            allow_collision="true"
            task="{mtc_task}"
            object_names="grocery_item;grasp_link;epick_suction_cup;epick_extension;epick_body;epick_tcp"
          />
          <Action
            ID="SetupMTCIgnoreCollisionsBetweenObjects"
            allow_collision="true"
            task="{mtc_task}"
            object_names="grocery_item;calibrated_top_shelf;calibrated_bottom_shelf;shelf_back;shelf_base;calibrated_bin;calibrated_pole;calibrated_camera;calibrated_table"
          />
          <Action
            ID="SetupMTCPlanToPose"
            acceleration_scale_factor="1.000000"
            ik_frame="grasp_link"
            keep_orientation="false"
            keep_orientation_link_names="grasp_link"
            keep_orientation_tolerance="0.100000"
            link_padding="0.005"
            max_iterations="5000"
            monitored_stage="current state"
            planning_group_name="manipulator"
            target_pose="{place_pose_fallback}"
            task="{mtc_task}"
            trajectory_sampling_rate="100"
            velocity_scale_factor="0.500000"
          />
          <Action
            ID="PlanMTCTask"
            solution="{place_solution}"
            task="{mtc_task}"
            max_solutions="10"
          />
        </Control>
      </Control>

      <Action ID="WaitForUserTrajectoryApproval" solution="{place_solution}" />
      <SubTree
        ID="Execute MTC Solution"
        solution="{place_solution}"
        execution_pipeline="jtc"
        controller_names="joint_trajectory_controller"
        controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
        _collapsed="true"
      />

      <!--=== STEP 12: FORCE-LOWER UNTIL CONTACT ===-->
      <Action
        ID="SwitchController"
        activate_controllers="velocity_force_controller"
        controller_list_action_name="/controller_manager/list_controllers"
      />
      <Action
        ID="CallTriggerService"
        service_name="/velocity_force_controller/zero_fts"
      />
      <Action ID="WaitForDuration" delay_duration="1.0" />
      <Action
        ID="CreateStampedWrench"
        stamped_wrench="{desired_wrench}"
        reference_frame="grasp_link"
        torque_xyz="0;0;0"
        force_xyz="0;0;0"
      />
      <!--Lower in world -Z (downward) to place object onto shelf surface-->
      <Action
        ID="CreateStampedTwist"
        reference_frame="world"
        stamped_twist="{desired_twist}"
        angular_velocity_xyz="0;0;0"
        linear_velocity_xyz="0;0;-0.005"
      />
      <Action
        ID="CreateStampedPose"
        reference_frame="grasp_link"
        stamped_pose="{initial_pose}"
      />
      <Action
        ID="TransformPoseFrame"
        output_pose="{initial_pose}"
        input_pose="{initial_pose}"
      />
      <Control ID="Parallel" failure_count="1" success_count="1">
        <Action
          ID="ForceExceedsThreshold"
          minimum_consecutive_wrench_values="10"
          wrench_frame_name="tool0"
          hand_frame_name="grasp_link"
          force_threshold="25"
        />
        <Action
          ID="PublishVelocityForceCommand"
          force_controlled_axes="0;0;0;0;0;0"
          wrench_gain="0.01"
          velocity_controlled_axes="0;0;1;0;0;0"
          publish_rate="50"
          velocity_force_controller_command_topic="/velocity_force_controller/command"
        />
      </Control>
      <SubTree
        ID="Force Relaxation"
        _collapsed="true"
        wrench_gain="0.01"
        relaxation_time_ms="300"
        tip_link="grasp_link"
      />
      <Action
        ID="SwitchController"
        activate_controllers="joint_trajectory_controller"
      />

      <!--=== STEP 13: RELEASE, DETACH, AND RETRACT ===-->
      <SubTree ID="Deactivate Vacuum" _collapsed="true" />
      <Action ID="WaitForDuration" delay_duration="1.0" />
      <Action ID="DetachURDF" urdf_name="grocery_item" />
      <Action ID="RemoveURDFFromScene" urdf_name="grocery_item" />
      <!--Retract upward-->
      <Action
        ID="CreateStampedPose"
        reference_frame="grasp_link"
        stamped_pose="{retract_pose}"
        position_xyz="0;0;-0.1"
      />
      <Action ID="ResetPoseStampedVector" vector="{retract_path}" />
      <Action ID="AddPoseStampedToVector" input="{retract_pose}" vector="{retract_path}" />
      <Action
        ID="PlanCartesianPath"
        acceleration_scale_factor="1.000000"
        blending_radius="0.020000"
        debug_solution="{debug_solution}"
        ik_cartesian_space_density="0.010000"
        ik_joint_space_density="0.100000"
        joint_trajectory_msg="{joint_trajectory_msg}"
        path="{retract_path}"
        planning_group_name="manipulator"
        position_only="false"
        tip_links="grasp_link"
        trajectory_sampling_rate="100"
        velocity_scale_factor="1.000000"
      />
      <Action
        ID="ExecuteTrajectory"
        execution_pipeline="jtc"
        controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
      />

      <Action
        ID="LogMessage"
        log_level="info"
        message="Pringles pick and place complete."
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Qualcomm Pick Pringles v3">
      <MetadataFields>
        <Metadata subcategory="Application - Grocery" />
        <Metadata runnable="true" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
