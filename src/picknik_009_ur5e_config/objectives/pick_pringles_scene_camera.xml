<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Pick Pringles Scene Camera">
  <BehaviorTree
    ID="Pick Pringles Scene Camera"
    _description="Uses the scene (bin) camera to detect Pringles via SAM3, selects the highest confidence mask, fits a primitive, plans a vacuum grasp, navigates to the object, and activates the vacuum."
    _favorite="true"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <!--=== CLEANUP ===-->
      <Decorator ID="ForceSuccess">
        <Action ID="DetachURDF" urdf_name="grocery_item" />
      </Decorator>
      <Decorator ID="ForceSuccess">
        <Action ID="RemoveURDFFromScene" urdf_name="grocery_item" />
      </Decorator>
      <SubTree ID="Deactivate Vacuum" _collapsed="true" />

      <!--=== STEP 1: GET SCENE CAMERA IMAGE AND POINT CLOUD ===-->
      <Action
        ID="GetImage"
        topic_name="/camera/scene_camera/color/image_raw"
        message_out="{scene_camera_image}"
      />
      <Action
        ID="GetCameraInfo"
        topic_name="/camera/scene_camera/color/camera_info"
        message_out="{scene_camera_info}"
      />
      <Action
        ID="GetPointCloud"
        topic_name="/camera/scene_camera/depth/color/points"
        message_timeout_sec="15"
        message_out="{scene_camera_point_cloud}"
      />
      <!--Point cloud visualization disabled — use TransformPointCloudFrame later instead-->

      <!--=== STEP 2: SEGMENT PRINGLES USING SAM3 ===-->
      <Action
        ID="LoadImageFromFile"
        file_path="~/user_ws/qualcomm_image_exemplars/pringles.png"
        frame_id="camera"
        image="{pringles_exemplar_image}"
      />
      <Action
        ID="GetMasks2DFromExemplar"
        model_package="picknik_009_ur5e_config"
        encoder_model_path="models/sam3_vision_encoder.onnx"
        decoder_model_path="models/sam3_decoder.onnx"
        geometry_encoder_model_path="models/sam3_geometry_encoder.onnx"
        text_encoder_model_path="models/sam3_text_encoder.onnx"
        confidence_threshold="0.5"
        confidence_scores_str="{confidence_scores_str}"
        target_image="{scene_camera_image}"
        exemplar_image="{pringles_exemplar_image}"
        text_prompt="a tall red can of Pringles potato chips. There is a white design on the side and the lid of the can."
        confidence_scores="{confidence_scores}"
        masks2d="{masks2d}"
      />
      <!--Visualize all masks-->
      <Action
        ID="PublishMask2D"
        bounding_box_labels="{confidence_scores_str}"
        image="{scene_camera_image}"
        masks="{masks2d}"
        masks_visualization_topic="/masks_visualization"
        opacity="0.500000"
      />

      <!--=== STEP 3: SELECT HIGHEST CONFIDENCE MASK ===-->
      <Action
        ID="GetHighestConfidenceMask"
        masks2d="{masks2d}"
        confidence_scores="{confidence_scores}"
        best_mask="{best_mask}"
        best_score="{best_score}"
      />

      <!--=== STEP 4: FIT PRIMITIVE TO SEGMENTED POINT CLOUD ===-->
      <Action
        ID="TransformPointCloudFrame"
        input_cloud="{scene_camera_point_cloud}"
        target_frame="world"
        output_cloud="{point_cloud_world}"
      />
      <!--Visualize full point cloud in world frame-->
      <Action ID="SendPointCloudToUI" point_cloud="{point_cloud_world}" />
      <!--Convert masks to 3D using the point cloud-->
      <Action
        ID="GetMasks3DFromMasks2D"
        camera_info="{scene_camera_info}"
        masks2d="{masks2d}"
        point_cloud="{point_cloud_world}"
        masks3d="{masks3d}"
      />
      <!--Shape fitting-->
      <Action
        ID="GetGraspableGroceryObjectsFromMasks3D"
        point_cloud="{point_cloud_world}"
        masks3d="{masks3d}"
        base_frame="world"
        plane_inlier_threshold="0.020000"
        minimum_face_area="0"
        face_separation_threshold="0.025000"
        max_objects="1"
        shape_type="cylinder"
        graspable_objects="{grocery_objects}"
        segment_cloud="{segment_cloud}"
      />
      <!--Publish and visualize segment cloud-->
      <Action
        ID="PublishPointCloud"
        point_cloud="{segment_cloud}"
        point_cloud_topic="/grocery_segment_cloud"
      />
      <Action ID="SendPointCloudToUI" point_cloud="{segment_cloud}" />
      <!--Get the fitted object-->
      <Action
        ID="GetElementOfVector"
        vector_in="{grocery_objects}"
        index="0"
        element="{graspable_object}"
      />
      <Action
        ID="ExtractGraspableObjectPose"
        graspable_object="{graspable_object}"
        pose="{object_pose}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="detected_object"
        marker_size="0.050000"
        pose="{object_pose}"
        marker_text="pringles"
      />

      <!--=== STEP 5: GENERATE VACUUM GRASP POSES ===-->
      <Action
        ID="GetCurrentPlanningScene"
        planning_scene_msg="{planning_scene_msg}"
      />
      <Action
        ID="GetLatestTransform"
        target_frame_id="grasp_link"
        source_frame_id="epick_tcp"
        transform="{ee_to_tcp_tf_stamped}"
      />
      <Action
        ID="ConvertTransformStampedToPoseStamped"
        transform_stamped="{ee_to_tcp_tf_stamped}"
        pose_stamped="{ee_to_tcp_pose}"
      />
      <Action
        ID="GenerateVacuumGraspPoses"
        target_object="{graspable_object}"
        planning_scene_msg="{planning_scene_msg}"
        end_effector_group_name="gripper"
        ui_grasp_link="grasp_link"
        generate_centroid_grasps="true"
        padding_dimension="0.01"
        samples_per_plane="3"
        num_orientation_samples="4"
        ee_to_tcp_tf="{ee_to_tcp_pose}"
        grasp_poses="{grasp_poses}"
      />

      <!--=== STEP 6: PLAN AND EXECUTE PICK ===-->
      <!--Use the first grasp pose-->
      <Action
        ID="GetElementOfVector"
        vector_in="{grasp_poses}"
        index="0"
        element="{pick_pose}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="pick"
        marker_size="0.050000"
        pose="{pick_pose}"
        marker_text="pick"
      />
      <!--MTC: plan to pick pose-->
      <Action
        ID="InitializeMTCTask"
        task="{mtc_task}"
        trajectory_monitoring="false"
        controller_names="joint_trajectory_controller"
        task_id="pick_pringles"
        timeout="-1.000000"
      />
      <Action ID="SetupMTCCurrentState" task="{mtc_task}" />
      <Action
        ID="SetupMTCPlanToPose"
        acceleration_scale_factor="1.000000"
        ik_frame="grasp_link"
        keep_orientation="false"
        keep_orientation_link_names="grasp_link"
        keep_orientation_tolerance="0.100000"
        link_padding="0.005000"
        max_iterations="10000"
        monitored_stage="current state"
        planning_group_name="manipulator"
        target_pose="{pick_pose}"
        task="{mtc_task}"
        trajectory_sampling_rate="100"
        velocity_scale_factor="1.000000"
      />
      <Action
        ID="PlanMTCTask"
        solution="{pick_solution}"
        task="{mtc_task}"
        max_solutions="3"
      />
      <Action ID="WaitForUserTrajectoryApproval" solution="{pick_solution}" />
      <SubTree
        ID="Execute MTC Solution"
        solution="{pick_solution}"
        execution_pipeline="jtc"
        controller_names="joint_trajectory_controller"
        controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
        _collapsed="true"
      />

      <!--=== STEP 7: ACTIVATE VACUUM AND CHECK GRIP ===-->
      <SubTree ID="Activate Vacuum" _collapsed="true" />
      <Decorator ID="Repeat" num_cycles="3">
        <Control ID="Fallback" name="GripOrNudge">
          <Control ID="Sequence" name="CheckGrip">
            <Action ID="WaitForDuration" delay_duration="2.0" />
            <Action
              ID="GetEpickObjectDetectionStatus"
              topic_name="/object_detection_status"
              message_out="{vacuum_status}"
            />
            <Control ID="Fallback">
              <Action
                ID="CompareEpickObjectDetectionStatus"
                value1="{vacuum_status}"
                value2="OBJECT_DETECTED_AT_MAX_PRESSURE"
              />
              <Action
                ID="CompareEpickObjectDetectionStatus"
                value1="{vacuum_status}"
                value2="OBJECT_DETECTED_AT_MIN_PRESSURE"
              />
            </Control>
          </Control>
          <Control ID="Sequence" name="NudgeDown">
            <Action
              ID="LogMessage"
              log_level="info"
              message="No vacuum grip detected. Nudging down 1cm..."
            />
            <Action
              ID="CreateStampedPose"
              reference_frame="grasp_link"
              stamped_pose="{nudge_pose}"
              position_xyz="0;0;0.01"
            />
            <Action ID="ResetPoseStampedVector" vector="{nudge_path}" />
            <Action
              ID="AddPoseStampedToVector"
              input="{nudge_pose}"
              vector="{nudge_path}"
            />
            <Action
              ID="PlanCartesianPath"
              acceleration_scale_factor="0.500000"
              blending_radius="0.005000"
              debug_solution="{debug_solution}"
              ik_cartesian_space_density="0.005000"
              ik_joint_space_density="0.050000"
              joint_trajectory_msg="{joint_trajectory_msg}"
              path="{nudge_path}"
              planning_group_name="manipulator"
              position_only="false"
              tip_links="grasp_link"
              trajectory_sampling_rate="100"
              velocity_scale_factor="0.100000"
            />
            <Action
              ID="ExecuteTrajectory"
              execution_pipeline="jtc"
              controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
            />
          </Control>
        </Control>
      </Decorator>
      <!--Final grip check-->
      <Action
        ID="GetEpickObjectDetectionStatus"
        topic_name="/object_detection_status"
        message_out="{vacuum_status}"
      />
      <Control ID="Fallback" name="FinalGripCheck">
        <Action
          ID="CompareEpickObjectDetectionStatus"
          value1="{vacuum_status}"
          value2="OBJECT_DETECTED_AT_MAX_PRESSURE"
        />
        <Action
          ID="CompareEpickObjectDetectionStatus"
          value1="{vacuum_status}"
          value2="OBJECT_DETECTED_AT_MIN_PRESSURE"
        />
      </Control>

      <Action
        ID="LogMessage"
        log_level="info"
        message="Pringles picked successfully with vacuum grip confirmed."
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Pick Pringles Scene Camera">
      <MetadataFields>
        <Metadata subcategory="Application - Grocery" />
        <Metadata runnable="true" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
