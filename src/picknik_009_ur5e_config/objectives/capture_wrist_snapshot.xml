<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Capture Wrist Snapshot">
  <BehaviorTree
    ID="Capture Wrist Snapshot"
    _description="Captures the wrist camera RGB image and point cloud and saves both to /home/ur5e-009-agent/user_ws/wrist_snapshots/ with timestamped filenames."
    _favorite="true"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <SubTree ID="Take Wrist Camera Image" _collapsed="true" />
      <SubTree ID="Get Wrist Camera Point Cloud" _collapsed="true" />
      <Action ID="SendPointCloudToUI" point_cloud="{wrist_camera_point_cloud}" />

      <Action
        ID="SaveImageToFile"
        file_path="/home/ur5e-009-agent/user_ws/wrist_snapshots"
        file_prefix="wrist_rgb"
        image="{wrist_camera_image}"
      />
      <Action
        ID="SavePointCloudToFile"
        file_path="/home/ur5e-009-agent/user_ws/wrist_snapshots"
        file_prefix="wrist_pcd"
        point_cloud="{wrist_camera_point_cloud}"
      />
      <Action
        ID="LogMessage"
        log_level="info"
        message="Wrist snapshot saved to /home/ur5e-009-agent/user_ws/wrist_snapshots/"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Capture Wrist Snapshot">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Application - Grocery" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
