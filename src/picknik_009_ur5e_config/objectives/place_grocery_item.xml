<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Place Grocery Item">
  <BehaviorTree
    ID="Place Grocery Item"
    _description="Places an already-grasped grocery item at the saved shelf target with the longest axis perpendicular to the shelf. Assumes vacuum is active and object is held. Run Save Shelf Target first."
    _favorite="true"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <!--Clean up any leftover collision objects from previous runs-->
      <Decorator ID="ForceSuccess">
        <Action ID="DetachURDF" urdf_name="grocery_item" />
      </Decorator>
      <Decorator ID="ForceSuccess">
        <Action ID="RemoveURDFFromScene" urdf_name="grocery_item" />
      </Decorator>
      <!--=== STEP 1: LOAD SHELF TARGET from YAML ===-->
      <Action
        ID="LoadTransformStampedFromYaml"
        file_path="shelf_target.yaml"
        output="{shelf_target_tf_stamped}"
      />
      <Action
        ID="ConvertTransformStampedToPoseStamped"
        transform_stamped="{shelf_target_tf_stamped}"
        pose_stamped="{shelf_target_pose}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="shelf_target"
        marker_size="0.050000"
        pose="{shelf_target_pose}"
        marker_text="shelf target"
      />
      <!--=== STEP 2: BUILD COLLISION OBJECT from input parameters ===-->
      <!--For a cylinder grasped in the middle:
          place_height = full height (object stands on flat end)
          collision origin is at center (no offset needed)-->
      <Action
        ID="GenerateShapeUrdf"
        shape_type="{shape_type}"
        dimensions="{collision_dimensions}"
        object_name="grocery_item"
        origin_offset_z="0.0"
        urdf_file_path="/tmp/grocery_item_collision.urdf"
        output_file_path="{generated_urdf_path}"
      />
      <!--Compute place height from shape: cylinder=height, box=longest dim, sphere=diameter-->
      <Action ID="Script" code="place_height := 0.0" />
      <!--Add collision object at current grasp_link pose and attach-->
      <Action
        ID="GetLatestTransform"
        target_frame_id="world"
        source_frame_id="grasp_link"
        transform="{current_grasp_tf}"
      />
      <Action
        ID="ConvertTransformStampedToPoseStamped"
        transform_stamped="{current_grasp_tf}"
        pose_stamped="{current_grasp_pose}"
      />
      <Action
        ID="AddURDF"
        urdf_name="grocery_item"
        urdf_pose="{current_grasp_pose}"
        package_name=""
        urdf_file_path="{generated_urdf_path}"
      />
      <Action
        ID="AttachURDF"
        urdf_name="grocery_item"
        allowed_collision_links="grasp_link;epick_suction_cup"
        parent_link_name="grasp_link"
      />
      <!--=== STEP 3: COMPUTE PLACE POSE ===-->
      <!--Build the place pose: shelf target position, gripper pointing down,
        offset upward by place_height so the object bottom touches the shelf.-->
      <Action
        ID="OverridePoseOrientation"
        input_pose="{shelf_target_pose}"
        orientation_xyzw="1;0;0;0"
        output_pose="{place_pose}"
      />
      <Action
        ID="TransformPose"
        input_pose="{place_pose}"
        translation_xyz="{place_translation_xyz}"
        quaternion_xyzw="0;0;0;1"
        output_pose="{place_pose}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="place_target"
        marker_size="0.050000"
        pose="{place_pose}"
        marker_text="place"
      />
      <!--=== STEP 4: PLAN AND EXECUTE PLACE ===-->
      <Action
        ID="InitializeMTCTask"
        controller_names="joint_trajectory_controller"
        task="{mtc_task}"
        task_id="place_grocery_item"
        trajectory_monitoring="false"
        timeout="-1.000000"
      />
      <Action ID="SetupMTCCurrentState" task="{mtc_task}" />
      <!--Allow collisions between the attached grocery item and nearby robot links-->
      <Action
        ID="SetupMTCIgnoreCollisionsBetweenObjects"
        allow_collision="true"
        task="{mtc_task}"
        object_names="grasp_link;grocery_item"
      />
      <Action
        ID="SetupMTCPlanToPose"
        acceleration_scale_factor="1.000000"
        ik_frame="grasp_link"
        keep_orientation="false"
        keep_orientation_link_names="grasp_link"
        keep_orientation_tolerance="0.100000"
        link_padding="0.005"
        max_iterations="5000"
        monitored_stage="current state"
        planning_group_name="manipulator"
        target_pose="{place_pose}"
        task="{mtc_task}"
        trajectory_sampling_rate="100"
        velocity_scale_factor="0.500000"
      />
      <Action
        ID="PlanMTCTask"
        solution="{mtc_solution}"
        task="{mtc_task}"
        max_solutions="1"
      />
      <Action ID="WaitForUserTrajectoryApproval" solution="{mtc_solution}" />
      <SubTree
        ID="Execute MTC Solution"
        solution="{mtc_solution}"
        execution_pipeline="jtc"
        controller_names="joint_trajectory_controller"
        controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
        _collapsed="true"
      />
      <!--=== STEP 4b: LOWER UNTIL CONTACT using force feedback ===-->
      <Action
        ID="SwitchController"
        activate_controllers="velocity_force_controller"
        controller_list_action_name="/controller_manager/list_controllers"
      />
      <Action
        ID="CallTriggerService"
        service_name="/velocity_force_controller/zero_fts"
      />
      <Action ID="WaitForDuration" delay_duration="1.0" />
      <Action
        ID="CreateStampedWrench"
        stamped_wrench="{desired_wrench}"
        reference_frame="grasp_link"
        torque_xyz="0;0;0"
        force_xyz="0;0;0"
      />
      <Action
        ID="CreateStampedTwist"
        reference_frame="grasp_link"
        stamped_twist="{desired_twist}"
        angular_velocity_xyz="0;0;0"
        linear_velocity_xyz="0;0;0.005"
      />
      <Action
        ID="CreateStampedPose"
        reference_frame="grasp_link"
        stamped_pose="{initial_pose}"
      />
      <Action
        ID="TransformPoseFrame"
        output_pose="{initial_pose}"
        input_pose="{initial_pose}"
      />
      <Control ID="Parallel" failure_count="1" success_count="1">
        <Action
          ID="ForceExceedsThreshold"
          minimum_consecutive_wrench_values="10"
          wrench_frame_name="tool0"
          hand_frame_name="grasp_link"
          force_threshold="5"
        />
        <Action
          ID="PublishVelocityForceCommand"
          force_controlled_axes="0;0;0;0;0;0"
          wrench_gain="0.01"
          velocity_controlled_axes="0;0;1;0;0;0"
          publish_rate="50"
        />
      </Control>
      <SubTree
        ID="Force Relaxation"
        _collapsed="true"
        wrench_gain="0.01"
        relaxation_time_ms="300"
        tip_link="grasp_link"
      />
      <Action
        ID="SwitchController"
        activate_controllers="joint_trajectory_controller"
      />
      <!--=== STEP 5: DEACTIVATE VACUUM, DETACH OBJECT, AND RETRACT ===-->
      <SubTree ID="Deactivate Vacuum" _collapsed="true" />
      <Action ID="WaitForDuration" delay_duration="1.0" />
      <!--Detach and remove the collision object from the planning scene-->
      <Action ID="DetachURDF" urdf_name="grocery_item" />
      <Action ID="RemoveURDFFromScene" urdf_name="grocery_item" />
      <!--Retract upward after releasing-->
      <Action
        ID="CreateStampedPose"
        reference_frame="grasp_link"
        stamped_pose="{retract_pose}"
        position_xyz="0;0;-0.1"
      />
      <Action ID="ResetPoseStampedVector" vector="{retract_path}" />
      <Action
        ID="AddPoseStampedToVector"
        input="{retract_pose}"
        vector="{retract_path}"
      />
      <Action
        ID="PlanCartesianPath"
        acceleration_scale_factor="1.000000"
        blending_radius="0.020000"
        debug_solution="{debug_solution}"
        ik_cartesian_space_density="0.010000"
        ik_joint_space_density="0.100000"
        joint_trajectory_msg="{joint_trajectory_msg}"
        path="{retract_path}"
        planning_group_name="manipulator"
        position_only="false"
        tip_links="grasp_link"
        trajectory_sampling_rate="100"
        velocity_scale_factor="1.000000"
      />
      <Action
        ID="ExecuteTrajectory"
        execution_pipeline="jtc"
        controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel />
</root>
