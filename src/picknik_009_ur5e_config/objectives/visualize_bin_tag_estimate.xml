<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Visualize Bin Tag Estimate">
  <BehaviorTree
    ID="Visualize Bin Tag Estimate"
    _description="Visualizes the expected bin AprilTag position based on known offsets from the bin opening center. Use this to verify the tag offset assumptions are correct."
    _favorite="true"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <!--Bin opening center estimate from environment.xacro-->
      <Action
        ID="CreateStampedPose"
        position_xyz="0.0;-0.74;0.126"
        orientation_xyzw="0;0;0;1"
        reference_frame="world"
        stamped_pose="{bin_opening_center}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="bin_opening_center"
        marker_size="0.080000"
        pose="{bin_opening_center}"
        marker_text="Bin Opening Center"
      />

      <!--Tag 4 expected position: bin_opening_center + (-0.2525, +0.18125, -0.0525)
          X: 25.25cm left
          Y: 18.125cm toward robot (+Y)
          Z: 5.25cm down -->
      <Action
        ID="TransformPose"
        input_pose="{bin_opening_center}"
        output_pose="{tag4_expected}"
        translation_xyz="-0.2525;0.18125;-0.0525"
        quaternion_xyzw="0;0;0;1"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.000000"
        marker_name="tag4_expected"
        marker_size="0.105000"
        pose="{tag4_expected}"
        marker_text="Tag 4 Expected"
      />

      <Action
        ID="LogMessage"
        log_level="info"
        message="Bin opening center and expected tag 4 position visualized. Check RViz."
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Visualize Bin Tag Estimate">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Application - Grocery" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
