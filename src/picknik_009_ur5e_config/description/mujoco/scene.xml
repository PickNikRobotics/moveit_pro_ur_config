<mujoco model="ur5e_epick_scene">
  <include file="ur5e_epick_globals.xml" />

  <compiler angle="radian" autolimits="true" />

  <option integrator="implicitfast" />

  <asset>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
      width="300" height="300" />
    <material name="groundplane" texture="groundplane" texuniform="true"
      texrepeat="5 5" reflectance="0.2" />
    <mesh name="workcell_mesh" file="workcell_no_totes.stl" />
  </asset>

  <worldbody>
    <light pos="0 0 2.0" dir="0 0 -1" directional="true" />
    <light
      name="spotlight"
      mode="targetbodycom"
      target="wrist_2_link"
      pos="0 -1 2"
    />

    <!-- Floor -->
    <geom
      name="floor"
      pos="0 0 -0.5"
      size="0 0 0.05"
      type="plane"
      material="groundplane"
    />

    <!-- Scene Camera -->
    <site
      name="scene_camera_optical_frame"
      pos="0.372 0.644 0.726"
      euler="-1.5708 0 -1.5708"
    />
    <camera
      name="scene_camera"
      pos="0.372 0.644 0.726"
      fovy="58"
      mode="fixed"
      resolution="640 480"
      euler="0 1.5708 0"
    />

    <!-- Workcell (80/20 frame) positioned so robot_mount aligns with origin -->
    <body name="workcell_body" pos="0.026 0.28 0.2" euler="0 0 -1.5708">
      <geom
        type="mesh"
        mesh="workcell_mesh"
        rgba="0.792 0.820 0.933 1"
        contype="1"
        conaffinity="1"
      />
    </body>

    <!-- Left tote (relative to workcell) -->
    <body name="left_tote" pos="-0.081 -0.246 -0.01" euler="0 0 1.5708">
      <!-- Bottom -->
      <geom type="box" size="0.3048 0.1905 0.0025" pos="0.3048 0.1905 0.0025" rgba="0.5 0.5 0.5 1" />
      <!-- Back wall -->
      <geom type="box" size="0.0125 0.1905 0.09525" pos="0.0125 0.1905 0.09525" rgba="0.5 0.5 0.5 1" />
      <!-- Front wall -->
      <geom type="box" size="0.0125 0.1905 0.09525" pos="0.5971 0.1905 0.09525" rgba="0.5 0.5 0.5 1" />
      <!-- Right wall -->
      <geom type="box" size="0.3048 0.0125 0.09525" pos="0.3048 0.0125 0.09525" rgba="0.5 0.5 0.5 1" />
      <!-- Left wall -->
      <geom type="box" size="0.3048 0.0125 0.09525" pos="0.3048 0.3685 0.09525" rgba="0.5 0.5 0.5 1" />
    </body>

    <!-- Right tote (relative to workcell) -->
    <body name="right_tote" pos="0.374 -0.246 -0.01" euler="0 0 1.5708">
      <!-- Bottom -->
      <geom type="box" size="0.3048 0.1905 0.0025" pos="0.3048 0.1905 0.0025" rgba="0.5 0.5 0.5 1" />
      <!-- Back wall -->
      <geom type="box" size="0.0125 0.1905 0.09525" pos="0.0125 0.1905 0.09525" rgba="0.5 0.5 0.5 1" />
      <!-- Front wall -->
      <geom type="box" size="0.0125 0.1905 0.09525" pos="0.5971 0.1905 0.09525" rgba="0.5 0.5 0.5 1" />
      <!-- Right wall -->
      <geom type="box" size="0.3048 0.0125 0.09525" pos="0.3048 0.0125 0.09525" rgba="0.5 0.5 0.5 1" />
      <!-- Left wall -->
      <geom type="box" size="0.3048 0.0125 0.09525" pos="0.3048 0.3685 0.09525" rgba="0.5 0.5 0.5 1" />
    </body>

    <!-- UR5e with EPick -->
    <include file="ur5e_epick.xml" />
  </worldbody>

  <keyframe>
    <key
      name="default"
      qpos="0 -1.5708 1.5708 -1.5708 -1.5708 0 0"
      ctrl="0 -1.5708 1.5708 -1.5708 -1.5708 0"
    />
  </keyframe>
</mujoco>
